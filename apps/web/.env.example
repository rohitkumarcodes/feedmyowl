# =============================================================================
# FeedMyOwl — Environment Variables
# =============================================================================
# Copy this file to .env.local and fill in your actual values.
# NEVER commit .env.local to git — it contains secrets.
# =============================================================================

# --- Database (Neon PostgreSQL) ---
# Get this from your Neon dashboard: https://console.neon.tech/
DATABASE_URL=postgresql://user:password@host/dbname?sslmode=require

# Public app URL (used by app links)
NEXT_PUBLIC_APP_URL=https://app.feedmyowl.com
