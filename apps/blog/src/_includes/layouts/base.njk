{#
  Base layout for all public website pages.
  Keeps navigation minimal and content typography-forward.
#}
<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{{ title or metadata.title }}</title>
    <meta name="description" content="{{ description or metadata.description }}" />
    <link rel="icon" href="data:image/svg+xml,%3Csvg%20xmlns%3D'http%3A%2F%2Fwww.w3.org%2F2000%2Fsvg'%20viewBox%3D'0%200%20256%20256'%3E%3Ctext%20x%3D'50%25'%20y%3D'56%25'%20font-size%3D'132'%20font-weight%3D'700'%20text-anchor%3D'middle'%20dominant-baseline%3D'middle'%20font-family%3D'ui-monospace%2C%20SFMono-Regular%2C%20Menlo%2C%20monospace'%20fill%3D'%231f2328'%3Eo%2Co%3C%2Ftext%3E%3C%2Fsvg%3E" />
    <link rel="stylesheet" href="/css/style.css" />
    <link rel="alternate" href="{{ metadata.feed.path }}" type="application/atom+xml" title="{{ metadata.title }}" />
  </head>
  <body class="reader-root sans-serif">
    <header class="site-header">
      <nav class="site-nav" aria-label="Main navigation">
        <a href="/" class="site-brand">feed my owl</a>
        <ul class="menu-links" role="list">
          <li><a href="/about/" {% if page.url == "/about/" %}aria-current="page"{% endif %}>about</a></li>
          <li><a href="/features/" {% if page.url == "/features/" %}aria-current="page"{% endif %}>features</a></li>
          <li><a href="/contact/" {% if page.url == "/contact/" %}aria-current="page"{% endif %}>contact</a></li>
          <li><a href="/blog/" {% if page.url == "/blog/" %}aria-current="page"{% endif %}>blog</a></li>
          <li><a href="/docs/" {% if page.url == "/docs/" %}aria-current="page"{% endif %}>docs</a></li>
          <li><a href="/changelog/" {% if page.url == "/changelog/" %}aria-current="page"{% endif %}>changelog</a></li>
        </ul>
      </nav>
    </header>

    <main class="site-main">
      {{ content | safe }}
    </main>
  </body>
</html>
