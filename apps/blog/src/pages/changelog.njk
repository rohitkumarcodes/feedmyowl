---
layout: layouts/base.njk
title: changelog — feedmyowl
permalink: /changelog/
---
<article class="reader-page">
  <h1>changelog</h1>

  {% set changelogEntries = collections.changelog | reverse %}
  {% if changelogEntries.length %}
    <ul class="entry-list">
      {% for entry in changelogEntries %}
        <li>
          <h2><a href="{{ entry.url }}">{{ entry.data.title }}</a></h2>
          <p class="entry-meta">{{ entry.date | readableDate }}</p>
          <p>
            {{ (entry.data.description or entry.templateContent | striptags) | truncate(280, true, "…") }}
          </p>
        </li>
      {% endfor %}
    </ul>
  {% else %}
    <p>no changelog entries yet.</p>
  {% endif %}
</article>
