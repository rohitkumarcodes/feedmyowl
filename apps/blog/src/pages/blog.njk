---
layout: layouts/base.njk
title: blog — feedmyowl
permalink: /blog/
---
<article class="container reader-page moz-reader-content">
  <h1>blog</h1>

  {% set postslist = collections.posts | reverse %}
  {% if postslist.length %}
    <ul class="entry-list">
      {% for post in postslist %}
        <li>
          <h2><a href="{{ post.url }}">{{ post.data.title }}</a></h2>
          <p class="entry-meta">{{ post.date | readableDate }}</p>
          <p>
            {{ (post.data.description or post.templateContent | striptags) | truncate(320, true, "…") }}
          </p>
        </li>
      {% endfor %}
    </ul>
  {% else %}
    <p>no posts yet.</p>
  {% endif %}
</article>
